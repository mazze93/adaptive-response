{
  "name": "adaptive-response",
  "private": true,
  "scripts": {
    "build":     "pnpm -r --filter './packages/**' build",
    "dev:api":   "pnpm --filter @adaptive/api dev",
    "dev:demo":  "pnpm --filter @adaptive/demo dev",
    "test":      "pnpm -r --filter './packages/**' test",
    "typecheck": "pnpm -r typecheck",
    "clean":     "find . -name 'dist' -not -path '*/node_modules/*' | xargs rm -rf"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
